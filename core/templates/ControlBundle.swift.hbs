import WidgetKit
import SwiftUI

// ─────────────────────────────────────────────────────────────────────────
//  📄  ControlBundle.swift
//  위젯 익스텐션 진입점 — iOS가 이 @main 구조체를 통해 모든 컨트롤을 인식.
//  controls.ts에 선언된 모든 컨트롤이 여기 등록됨.
// ─────────────────────────────────────────────────────────────────────────

@main
struct {{bundleStructName}}: WidgetBundle {
    var body: some Widget {
        {{#each controls}}
        {{pascalCase id}}Control()
        {{/each}}
    }
}
